generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(uuid())
  phone              String               @unique
  email              String?              @unique
  fullName           String
  nationalId         String?              @unique
  passwordHash       String
  type               UserType             @default(B2C)
  status             UserStatus           @default(ACTIVE)
  kycVerified        Boolean              @default(true)
  kycVerifiedAt      DateTime?
  deviceToken        String?
  refreshToken       String?
  refreshTokenExp    DateTime?
  pointsBalance      Int                  @default(0)
  walletBalance      Decimal              @default(0) @db.Decimal(12, 2)
  payLaterEligible   Boolean              @default(false)
  payLaterApprovedAt DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  lastLoginAt        DateTime?
  b2bAccount         B2BAccount?
  billReminders      BillReminder[]
  groupMembers       GroupPaymentMember[]
  requests           Request[]
  rewardTransactions RewardTransaction[]
  spendingRecords    SpendingRecord[]
  transactions       Transaction[]
  userNotifications  UserNotification[]
  vaultDocuments     VaultDocument[]
  requestMessages    RequestMessage[]

  @@map("users")
}

model Admin {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String
  role               AdminRole           @default(SUPPORT_AGENT)
  fullName           String
  deviceToken        String?
  isActive           Boolean             @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  adminNotifications AdminNotification[]
  auditLogs          AuditLog[]
  escalations        Escalation[]
  processedRequests  Request[]           @relation("Processor")
  requestMessages    RequestMessage[]

  @@map("admins")
}

model ServiceProvider {
  id             String          @id @default(uuid())
  name           String
  displayName    String
  category       ServiceCategory
  isActive       Boolean         @default(true)
  logoUrl        String?
  sortOrder      Int             @default(0)
  commissionRate Decimal         @default(0) @db.Decimal(5, 4)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  requests       Request[]
  subServices    SubService[]
  transactions   Transaction[]
  paymentNumbers PaymentNumber[]

  @@map("service_providers")
}

model SubService {
  id                String          @id @default(uuid())
  serviceProviderId String
  name              String
  nameAr            String
  description       String?
  category          ServiceCategory
  imageUrl          String?
  minAmount         Decimal?        @db.Decimal(10, 2)
  maxAmount         Decimal?        @db.Decimal(10, 2)
  fixedFee          Decimal         @default(0) @db.Decimal(8, 2)
  percentageFee     Decimal         @default(0) @db.Decimal(5, 4)
  quickAmounts      String?
  isActive          Boolean         @default(true)
  requiresPayLater  Boolean         @default(false)
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  requests          Request[]
  serviceProvider   ServiceProvider @relation(fields: [serviceProviderId], references: [id])

  @@map("sub_services")
}

model Request {
  id                String           @id @default(uuid())
  userId            String
  serviceProviderId String?
  subServiceId      String?
  type              RequestType
  status            RequestStatus    @default(PENDING)
  amount            Decimal          @db.Decimal(12, 2)
  fee               Decimal          @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal          @db.Decimal(12, 2)
  accountNumber     String?
  phoneNumber       String?
  metadata          String?
  proofImageUrl     String?
  paymentMethod     String?
  // Smart-billing: admin sets the bill amount AFTER receiving the request
  billingNumber     String?
  billingType       String?
  adminSetAmount    Decimal? @db.Decimal(12, 2)
  // Bank transfer fields
  receiverName      String?
  bankName          String?
  bankAccount       String?
  // InstaPay
  instapayId        String?
  processorId       String?
  adminNote         String?
  externalRef       String?
  slaDeadline       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  completedAt       DateTime?
  auditLogs         AuditLog[]
  b2bPayLater       B2BPayLater?
  escalations       Escalation[]
  messages          RequestMessage[]
  processor         Admin?           @relation("Processor", fields: [processorId], references: [id])
  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
  subService        SubService?      @relation(fields: [subServiceId], references: [id])
  user              User             @relation(fields: [userId], references: [id])
  transactions      Transaction[]

  @@index([status, createdAt])
  @@index([userId])
  @@index([slaDeadline])
  @@map("requests")
}

// Admin-managed wallet/InstaPay/bank numbers that clients are shown when they need to make an external payment.
model PaymentNumber {
  id                String              @id @default(uuid())
  type              PaymentNumberType
  number            String
  label             String
  serviceProviderId String?
  isActive          Boolean             @default(true)
  sortOrder         Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  serviceProvider   ServiceProvider?    @relation(fields: [serviceProviderId], references: [id])

  @@index([type, isActive])
  @@map("payment_numbers")
}

// In-app chat thread between a client and admins, scoped to one request.
model RequestMessage {
  id        String   @id @default(uuid())
  requestId String
  body      String
  // Sender is either a userId or adminId — exactly one is set.
  userId    String?
  adminId   String?
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  admin     Admin?   @relation(fields: [adminId], references: [id])

  @@index([requestId, createdAt])
  @@map("request_messages")
}

// Dynamic app-level settings (brand color, greeting, maintenance flag, etc.) — single key/value table.
model AdminSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string") // "string" | "json" | "bool" | "color" | "number"
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("admin_settings")
}

model Transaction {
  id                String            @id @default(uuid())
  userId            String
  requestId         String?
  serviceProviderId String?
  amount            Decimal           @db.Decimal(12, 2)
  fee               Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal           @db.Decimal(12, 2)
  status            TransactionStatus @default(PENDING)
  paymentMethod     String            @default("WALLET")
  externalRef       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  request           Request?          @relation(fields: [requestId], references: [id])
  serviceProvider   ServiceProvider?  @relation(fields: [serviceProviderId], references: [id])
  user              User              @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("transactions")
}

model B2BAccount {
  id              String         @id @default(uuid())
  userId          String         @unique
  companyName     String
  taxId           String         @unique
  commercialReg   String?        @unique
  contactName     String?
  contactPhone    String?
  creditLimit     Decimal        @default(0) @db.Decimal(14, 2)
  usedCredit      Decimal        @default(0) @db.Decimal(14, 2)
  payLaterStatus  PayLaterStatus @default(PENDING_APPROVAL)
  paymentTermDays Int            @default(30)
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id])
  b2bPayLaters    B2BPayLater[]
  groupPayments   GroupPayment[]

  @@map("b2b_accounts")
}

model B2BPayLater {
  id           String         @id @default(uuid())
  b2bAccountId String
  requestId    String         @unique
  amount       Decimal        @db.Decimal(14, 2)
  dueDate      DateTime
  settledAt    DateTime?
  status       PayLaterStatus @default(ACTIVE)
  invoiceNo    String         @unique
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  b2bAccount   B2BAccount     @relation(fields: [b2bAccountId], references: [id])
  request      Request        @relation(fields: [requestId], references: [id])

  @@index([status, dueDate])
  @@map("b2b_pay_laters")
}

model GroupPayment {
  id          String               @id @default(uuid())
  b2bId       String
  totalAmount Decimal              @db.Decimal(12, 2)
  status      RequestStatus        @default(PENDING)
  dueDate     DateTime
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     GroupPaymentMember[]
  b2bAccount  B2BAccount           @relation(fields: [b2bId], references: [id])

  @@map("group_payments")
}

model GroupPaymentMember {
  id           String       @id @default(uuid())
  groupId      String
  userId       String
  amount       Decimal      @db.Decimal(12, 2)
  paid         Boolean      @default(false)
  groupPayment GroupPayment @relation(fields: [groupId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@map("group_payment_members")
}

model UserNotification {
  id        String        @id @default(uuid())
  userId    String
  title     String
  body      String
  channel   NotifChannel  @default(IN_APP)
  priority  NotifPriority @default(MEDIUM)
  isRead    Boolean       @default(false)
  actionUrl String?
  data      Json?
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("user_notifications")
}

model AdminNotification {
  id        String        @id @default(uuid())
  adminId   String?
  title     String
  body      String
  priority  NotifPriority @default(HIGH)
  isRead    Boolean       @default(false)
  readAt    DateTime?
  requestId String?
  data      Json?
  createdAt DateTime      @default(now())
  admin     Admin?        @relation(fields: [adminId], references: [id])

  @@index([adminId, isRead])
  @@map("admin_notifications")
}

model RewardTransaction {
  id          String   @id @default(uuid())
  userId      String
  points      Int
  isEarned    Boolean
  reason      String
  referenceId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("reward_transactions")
}

model Voucher {
  id              String    @id @default(uuid())
  code            String    @unique
  discountPercent Decimal   @db.Decimal(5, 2)
  maxUses         Int       @default(1)
  usedCount       Int       @default(0)
  pointsCost      Int       @default(0)
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("vouchers")
}

model SpendingRecord {
  id       String  @id @default(uuid())
  userId   String
  category String
  amount   Decimal @db.Decimal(12, 2)
  month    String
  year     Int
  count    Int     @default(1)
  user     User    @relation(fields: [userId], references: [id])

  @@unique([userId, category, month, year])
  @@map("spending_records")
}

model VaultDocument {
  id           String   @id @default(uuid())
  userId       String
  documentType String
  encryptedUrl String
  iv           String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@map("vault_documents")
}

model BillReminder {
  id            String   @id @default(uuid())
  userId        String
  providerId    String
  accountNumber String
  amount        Decimal  @db.Decimal(12, 2)
  dueDate       DateTime
  isRecurring   Boolean  @default(false)
  frequency     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@map("bill_reminders")
}

model Escalation {
  id          String          @id @default(uuid())
  requestId   String
  level       EscalationLevel
  reason      String
  escalatedBy String
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  escalator   Admin           @relation(fields: [escalatedBy], references: [id])
  request     Request         @relation(fields: [requestId], references: [id])

  @@map("escalations")
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String?
  requestId String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  admin     Admin?   @relation(fields: [adminId], references: [id])
  request   Request? @relation(fields: [requestId], references: [id])

  @@map("audit_logs")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

enum UserType {
  B2C
  B2B
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_KYC
  BANNED
}

enum AdminRole {
  SUPER_ADMIN
  TRANSACTION_PROCESSOR
  B2B_MANAGER
  SUPPORT_AGENT
}

enum RequestStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  FAILED
  REJECTED
  REFUNDED
  ESCALATED
}

enum RequestType {
  MOBILE_RECHARGE
  BILL_PAYMENT
  INTERNET_RECHARGE
  B2B_PAY_LATER
  TRANSFER
  WALLET_TOPUP
  PAY_LATER_ACTIVATION
  VODAFONE_CASH_DEPOSIT
  INSTAPAY_DEPOSIT
  BANK_TRANSFER
  CUSTOM
}

enum PaymentNumberType {
  WALLET
  INSTAPAY
  BANK
}

enum ServiceType {
  RECHARGE
  BILL
  INSTAPAY
  TRANSFER
  CUSTOM
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ServiceCategory {
  TELECOM
  ELECTRICITY
  GAS
  WATER
  INTERNET
  INSURANCE
  GOVERNMENT
}

enum NotifChannel {
  PUSH
  SMS
  EMAIL
  IN_APP
}

enum NotifPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PayLaterStatus {
  PENDING_APPROVAL
  ACTIVE
  OVERDUE
  SETTLED
  SUSPENDED
  REJECTED
}

enum EscalationLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
}

enum B2BRequestStatus {
  PENDING
  APPROVED
  REJECTED
}
